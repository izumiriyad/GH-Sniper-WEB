{
  "name": "ghsniper-web",
  "version": "3.0.0",
  "description": "GHSniper Web — Server-side GrubHub block sniper",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:gc": "node --expose-gc -e \"require('tsx/cjs');require('./src/server.ts')\"",
    "build": "npx tsc",
    "start": "node --expose-gc dist/server.js",
    "prod": "npm run build && pm2 start ecosystem.config.js --node-args=\"--expose-gc\"",
    "logs": "pm2 logs ghsniper",
    "restart": "pm2 restart ghsniper"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "https-proxy-agent": "^9.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
